<script>
/* ================================================================
   REFRACT STORE — MAIN JS
   Store ID: a682b6fd-fb35-4866-b74f-715301caa309
   ================================================================ */

const STORE_ID = 'a682b6fd-fb35-4866-b74f-715301caa309';

// ---- STATE ----
let allProducts = [];
let allCategories = [];
let cart = JSON.parse(localStorage.getItem('refract_cart') || '[]');
let currentPage = 'home'; // 'home' | 'catalog' | 'product'
let previousPage = 'home';
let currentProductId = null;
let catalogFilter = 'all';
let productClickCounts = JSON.parse(localStorage.getItem('refract_clicks') || '{}');

// ---- NAVIGATION ----
function navigateTo(page, productId) {
  // hide all
  document.getElementById('home').classList.toggle('hidden', page !== 'home');
  document.getElementById('all-products-page').classList.toggle('active', page === 'catalog');
  document.getElementById('product-page').classList.toggle('active', page === 'product');

  previousPage = currentPage;
  currentPage = page;

  if (page === 'home') {
    history.pushState({page:'home'}, '', '#');
    window.scrollTo({ top: 0 });
  } else if (page === 'catalog') {
    history.pushState({page:'catalog'}, '', '#catalog');
    window.scrollTo({ top: 0 });
    renderCatalog(allProducts);
    buildCatalogFilters();
  } else if (page === 'product' && productId) {
    currentProductId = productId;
    history.pushState({page:'product', id: productId}, '', '#product-' + productId);
    window.scrollTo({ top: 0 });
    renderProductDetail(productId);
  }
}

function goBackFromProduct() {
  if (previousPage === 'catalog') {
    navigateTo('catalog');
  } else {
    navigateTo('home');
  }
}

function scrollToSection(id) {
  if (currentPage !== 'home') {
    navigateTo('home');
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    }, 100);
  } else {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth' });
  }
}

// Handle browser back/forward
window.addEventListener('popstate', function(e) {
  const hash = location.hash;
  if (!hash || hash === '#') {
    navigateTo('home');
  } else if (hash === '#catalog') {
    navigateTo('catalog');
  } else if (hash.startsWith('#product-')) {
    const id = hash.replace('#product-', '');
    navigateTo('product', id);
  }
});

// ---- NAVBAR SCROLL ----
window.addEventListener('scroll', () => {
  const nb = document.getElementById('navbar');
  if (window.scrollY > 40) {
    nb.classList.add('scrolled');
  } else {
    nb.classList.remove('scrolled');
  }
}, { passive: true });

// ---- KOMERZA STOREFRONT CLIENT LIBRARY ----
// The public, browser-safe way to load store data is the Komerza Client
// Library (cdn.komerza.com/komerza.min.js), initialized with the public
// store ID. Do NOT call api.komerza.com directly from the browser — those
// endpoints require a private API key (server-side only) and will return
// 401 Unauthorized from client-side code.
async function fetchStoreData() {
  if (typeof komerza === 'undefined') {
    console.error('Komerza client library failed to load (cdn.komerza.com/komerza.min.js).');
    return null;
  }
  try {
    komerza.init(STORE_ID);
    const response = await komerza.getStore();
    if (!response || !response.success) {
      console.error('Komerza getStore() failed:', response && response.message);
      return null;
    }
    return response.data;
  } catch (e) {
    console.error('Komerza getStore() threw an error:', e);
    return null;
  }
}

// ---- PRICE FORMATTING ----
function formatPrice(product) {
  const price = product.price || product.basePrice || product.variants?.[0]?.price || product.variants?.[0]?.cost || 0;
  const currency = product.currency || product.currencyCode || 'USD';
  if (price === 0) return 'Free';
  try {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency.toUpperCase() }).format(price / 100);
  } catch(e) {
    return '$' + (price / 100).toFixed(2);
  }
}

// ---- IMAGE HELPERS ----
function getProductImage(product) {
  if (product.images && product.images.length > 0) {
    const img = product.images[0];
    return img.url || img.src || img;
  }
  if (product.image) return product.image.url || product.image.src || product.image;
  if (product.thumbnail) return product.thumbnail;
  return null;
}

// ---- PRODUCT CARD HTML ----
function buildProductCard(product, categoryMap) {
  const img = getProductImage(product);
  const price = formatPrice(product);
  const catName = categoryMap[product.categoryId] || categoryMap[product.category] || '';
  const name = product.name || product.title || 'Unnamed Product';
  const desc = product.description || product.shortDescription || '';

  return `
    <div class="product-card" onclick="openProduct('${product.id || product._id}')">
      <div class="product-image-wrap">
        ${img
          ? `<img src="${img}" alt="${name}" loading="lazy" onerror="this.parentElement.innerHTML='<div class=\\'product-image-placeholder\\'>No Image</div>'" />`
          : '<div class="product-image-placeholder">No Image</div>'
        }
        <div class="product-overlay"></div>
        ${catName ? `<span class="product-badge">${catName}</span>` : ''}
      </div>
      <div class="product-info">
        <div class="product-name">${name}</div>
        ${desc ? `<div class="product-desc">${desc}</div>` : ''}
        <div class="product-footer">
          <span class="product-price">${price}</span>
          <button class="product-cta" onclick="event.stopPropagation(); addToCart(${JSON.stringify({id: product.id || product._id, name: name, price: price, image: img || ''}).replace(/"/g, '&quot;')})">Add to Cart</button>
        </div>
      </div>
    </div>
  `;
}

// ---- OPEN PRODUCT ----
function openProduct(id) {
  // track clicks
  productClickCounts[id] = (productClickCounts[id] || 0) + 1;
  localStorage.setItem('refract_clicks', JSON.stringify(productClickCounts));
  navigateTo('product', id);
}

// ---- RENDER PRODUCT DETAIL ----
function renderProductDetail(id) {
  const product = allProducts.find(p => (p.id || p._id) == id);
  if (!product) {
    document.getElementById('product-detail-info').innerHTML = '<p style="color:var(--text-muted)">Product not found.</p>';
    return;
  }

  const img = getProductImage(product);
  const price = formatPrice(product);
  const name = product.name || product.title || 'Unnamed Product';
  const desc = product.description || product.shortDescription || '';

  // Image
  const imgWrap = document.getElementById('product-detail-img-wrap');
  if (img) {
    imgWrap.innerHTML = `<img src="${img}" alt="${name}" style="width:100%;height:100%;object-fit:cover;" onerror="this.parentElement.innerHTML='<div class=\\'product-image-placeholder\\'>No Image</div>'" />`;
  } else {
    imgWrap.innerHTML = '<div class="product-image-placeholder">No Image</div>';
  }

  // Info
  const productId = product.id || product._id;
  document.getElementById('product-detail-info').innerHTML = `
    <h1 class="product-detail-name">${name}</h1>
    <div class="product-detail-price">${price}</div>
    ${desc ? `<p class="product-detail-desc">${desc}</p>` : ''}
    <div class="product-detail-meta">
      <div class="product-detail-meta-row">
        <span>Delivery</span><span>Instant & Automatic</span>
      </div>
      <div class="product-detail-meta-row">
        <span>Support</span><span>24/7 via Discord</span>
      </div>
      <div class="product-detail-meta-row">
        <span>Status</span><span style="color:#22c55e;">In Stock</span>
      </div>
    </div>
    <div class="product-detail-actions">
      <button class="btn-primary" style="flex:1;justify-content:center;" onclick="addToCart({id:'${productId}', name:${JSON.stringify(name)}, price:${JSON.stringify(price)}, image:${JSON.stringify(img || '')}})">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span>Add to Cart</span>
      </button>
      <button class="btn-outline" onclick="buyNow({id:'${productId}', name:${JSON.stringify(name)}, price:${JSON.stringify(price)}, image:${JSON.stringify(img || '')}})">
        Buy Now
      </button>
    </div>
  `;

  // Update title
  document.title = name + ' — REFRACT';
}

// ---- RENDER CATEGORIES ----
function buildCategoryMap(categories) {
  const map = {};
  for (const c of categories) {
    map[c.id || c._id] = c.name || c.title || '';
  }
  return map;
}

function getCategoryIcon(name) {
  name = (name || '').toLowerCase();
  if (name.includes('game') || name.includes('gaming')) return `<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16.5a2.5 2.5 0 01-5 0V8.5a2.5 2.5 0 015 0v8zm-9-1l-1.5-3h-5L4 15.5"/><path d="M6 9h.01M9 9h.01M3 12h18"/></svg>`;
  if (name.includes('skin') || name.includes('cosmetic')) return `<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`;
  if (name.includes('boost') || name.includes('rank')) return `<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`;
  if (name.includes('account') || name.includes('acc')) return `<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
  if (name.includes('currency') || name.includes('coin') || name.includes('credit')) return `<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`;
  return `<svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`;
}

function renderCategories(categories, products) {
  const grid = document.getElementById('categories-grid');
  if (!categories || categories.length === 0) {
    grid.innerHTML = '<p style="color:var(--text-muted);grid-column:1/-1;">No categories found.</p>';
    return;
  }
  // Count products per category
  const countMap = {};
  for (const p of products) {
    const cid = p.categoryId || p.category;
    if (cid) countMap[cid] = (countMap[cid] || 0) + 1;
  }

  grid.innerHTML = categories.map(cat => {
    const catId = cat.id || cat._id;
    const catName = cat.name || cat.title || 'Category';
    const count = countMap[catId] || 0;
    return `
      <div class="category-card" onclick="filterByCategory('${catId}', '${catName}')">
        <div class="category-icon">${getCategoryIcon(catName)}</div>
        <div class="category-name">${catName}</div>
        <div class="category-count">${count} product${count !== 1 ? 's' : ''}</div>
        <div class="category-arrow">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </div>
      </div>
    `;
  }).join('');
}

function filterByCategory(catId, catName) {
  navigateTo('catalog');
  setTimeout(() => {
    filterCatalog(catId, null);
    // highlight button
    const btns = document.querySelectorAll('.cat-filter-btn');
    btns.forEach(b => b.classList.remove('active'));
    const btn = Array.from(btns).find(b => b.dataset.catid === catId);
    if (btn) btn.classList.add('active');
  }, 50);
}

// ---- CATALOG ----
function buildCatalogFilters() {
  const bar = document.getElementById('catalog-filter-bar');
  bar.innerHTML = `<button class="cat-filter-btn active" onclick="filterCatalog('all', this)">All</button>`;
  for (const cat of allCategories) {
    const catId = cat.id || cat._id;
    const catName = cat.name || cat.title || 'Category';
    const btn = document.createElement('button');
    btn.className = 'cat-filter-btn';
    btn.dataset.catid = catId;
    btn.textContent = catName;
    btn.onclick = function() { filterCatalog(catId, this); };
    bar.appendChild(btn);
  }
}

function filterCatalog(catId, btn) {
  catalogFilter = catId;
  // update active
  document.querySelectorAll('.cat-filter-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  // filter
  const filtered = catId === 'all' ? allProducts : allProducts.filter(p => (p.categoryId || p.category) == catId);
  renderCatalog(filtered);
}

function renderCatalog(products) {
  const grid = document.getElementById('catalog-grid');
  if (!products || products.length === 0) {
    grid.innerHTML = '<p style="color:var(--text-muted);grid-column:1/-1;padding:40px 0;">No products found.</p>';
    return;
  }
  const categoryMap = buildCategoryMap(allCategories);
  grid.innerHTML = products.map(p => buildProductCard(p, categoryMap)).join('');
}

// ---- RENDER FEATURED PRODUCTS ----
function renderFeaturedProducts(products) {
  const grid = document.getElementById('products-grid');
  if (!products || products.length === 0) {
    grid.innerHTML = '<p style="color:var(--text-muted);grid-column:1/-1;">No products available.</p>';
    return;
  }
  const categoryMap = buildCategoryMap(allCategories);
  // Show first 6 (2 rows of 3)
  const featured = products.slice(0, 6);
  grid.innerHTML = featured.map(p => buildProductCard(p, categoryMap)).join('');
  document.getElementById('stat-products').textContent = products.length + '+';
  if (document.getElementById('products-section-title')) {
    document.getElementById('products-section-title').textContent = 'Products';
  }
}

// ---- RENDER BEST SELLERS ----
function renderBestSellers(products) {
  const grid = document.getElementById('best-grid');
  if (!products || products.length === 0) {
    grid.innerHTML = '<p style="color:var(--text-muted);grid-column:1/-1;">No products available.</p>';
    return;
  }
  // Sort by click count
  const sorted = [...products].sort((a, b) => {
    const idA = a.id || a._id;
    const idB = b.id || b._id;
    return (productClickCounts[idB] || 0) - (productClickCounts[idA] || 0);
  });
  const categoryMap = buildCategoryMap(allCategories);
  const best = sorted.slice(0, 3);
  grid.innerHTML = best.map(p => buildProductCard(p, categoryMap)).join('');
}

// ---- CART ----
function saveCart() {
  localStorage.setItem('refract_cart', JSON.stringify(cart));
  updateCartBadge();
}

function updateCartBadge() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  const badge = document.getElementById('cart-badge');
  badge.textContent = total;
  badge.classList.toggle('visible', total > 0);
}

function addToCart(product) {
  const existing = cart.find(i => i.id === product.id);
  if (existing) {
    existing.qty++;
  } else {
    cart.push({ ...product, qty: 1 });
  }
  saveCart();
  renderCart();
  showToast('Added to cart!');
}

function buyNow(product) {
  addToCart(product);
  openCart();
}

function removeFromCart(id) {
  cart = cart.filter(i => i.id !== id);
  saveCart();
  renderCart();
}

function changeQty(id, delta) {
  const item = cart.find(i => i.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) {
    cart = cart.filter(i => i.id !== id);
  }
  saveCart();
  renderCart();
}

function renderCart() {
  const body = document.getElementById('cart-body');
  const empty = document.getElementById('cart-empty');

  if (cart.length === 0) {
    body.innerHTML = '<div class="cart-empty" id="cart-empty">Your cart is empty.</div>';
    document.getElementById('cart-total').textContent = '$0.00';
    return;
  }

  let total = 0;
  body.innerHTML = cart.map(item => {
    // try to parse price
    let priceNum = 0;
    const priceStr = String(item.price || '0');
    const match = priceStr.match(/[\d.]+/);
    if (match) priceNum = parseFloat(match[0]) * item.qty;
    total += priceNum;

    return `
      <div class="cart-item">
        ${item.image ? `<img class="cart-item-img" src="${item.image}" alt="${item.name}" onerror="this.style.display='none'" />` : ''}
        <div class="cart-item-info">
          <div class="cart-item-name">${item.name}</div>
          <div class="cart-item-price">${item.price}</div>
          <div class="cart-item-qty">
            <button class="qty-btn" onclick="changeQty('${item.id}', -1)">-</button>
            <span class="qty-val">${item.qty}</span>
            <button class="qty-btn" onclick="changeQty('${item.id}', 1)">+</button>
          </div>
        </div>
        <button class="cart-item-remove" onclick="removeFromCart('${item.id}')" title="Remove">&#x2715;</button>
      </div>
    `;
  }).join('');

  document.getElementById('cart-total').textContent = '$' + total.toFixed(2);
}

function openCart() {
  document.getElementById('cart-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeCart() {
  document.getElementById('cart-modal').classList.remove('open');
  document.body.style.overflow = '';
}

function checkout() {
  if (cart.length === 0) {
    showToast('Your cart is empty!');
    return;
  }
  // Try Komerza checkout
  if (window.Komerza && typeof window.Komerza.checkout === 'function') {
    const items = cart.map(i => ({ productId: i.id, quantity: i.qty }));
    window.Komerza.checkout({ storeId: STORE_ID, items });
  } else if (window.KomerzaCheckout) {
    window.KomerzaCheckout.open({ storeId: STORE_ID, items: cart.map(i => ({ productId: i.id, quantity: i.qty })) });
  } else {
    showToast('Opening checkout...');
  }
}

// ---- FAQ TOGGLE ----
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(el => el.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}

// ---- TOAST ----
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timeout);
  t._timeout = setTimeout(() => t.classList.remove('show'), 2500);
}

// ---- MAIN INIT ----
async function init() {
  // Init cart
  updateCartBadge();
  renderCart();

  // Handle initial hash navigation
  const hash = location.hash;
  if (hash === '#catalog') {
    navigateTo('catalog');
  } else if (hash.startsWith('#product-')) {
    const id = hash.replace('#product-', '');
    // will render after products load
    currentProductId = id;
  }

  // Fetch store data via the Komerza Client Library (public, browser-safe)
  const store = await fetchStoreData();

  allProducts = (store && Array.isArray(store.products)) ? store.products : [];
  allCategories = (store && Array.isArray(store.categories)) ? store.categories : [];

  // Render
  renderFeaturedProducts(allProducts);
  renderBestSellers(allProducts);
  renderCategories(allCategories, allProducts);

  // If we were waiting for product page
  if (location.hash.startsWith('#product-') && currentProductId) {
    document.getElementById('home').classList.add('hidden');
    document.getElementById('product-page').classList.add('active');
    currentPage = 'product';
    renderProductDetail(currentProductId);
  } else if (location.hash === '#catalog') {
    buildCatalogFilters();
    renderCatalog(allProducts);
  }
}

// Start
init();
</script>

