  }

  function toggleSection(id) {
    const s = getSettings();
    s.sections = s.sections || {};
    s.sections[id] = !s.sections[id];
    if (s.sections[id] === undefined) s.sections[id] = true;
    saveSettings(s);
    applySettings(s);
  }

  function renderAdminFeatures(features) {
    const list = document.getElementById('admin-features-list');
    list.innerHTML = features.map((f, i) => `
      <div style="background:var(--bg-deep);border:1px solid var(--border);border-radius:var(--radius);padding:16px;display:flex;gap:12px;">
        <div style="flex:1;display:flex;flex-direction:column;gap:8px;">
          <input type="text" class="admin-input" placeholder="Title" value="${escHtml(f.title)}" id="af-title-${i}" />
          <input type="text" class="admin-input" placeholder="Description" value="${escHtml(f.desc)}" id="af-desc-${i}" />
        </div>
        <button onclick="removeAdminFeature(${i})" style="background:none;border:1px solid var(--border);border-radius:8px;color:var(--text-muted);padding:8px;cursor:pointer;height:fit-content;align-self:flex-start;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    `).join('');
  }

  function addAdminFeature() {
    const s = getSettings();
    s.features.push({ title: 'New Feature', desc: 'Feature description.' });
    saveSettings(s);
    renderAdminFeatures(s.features);
  }

  function removeAdminFeature(i) {
    const s = getSettings();
    s.features.splice(i, 1);
    saveSettings(s);
    renderAdminFeatures(s.features);
    renderFeatures(s.features);
  }

  function renderAdminFAQs(faqs) {
    const list = document.getElementById('admin-faq-list');
    list.innerHTML = faqs.map((faq, i) => `
      <div style="background:var(--bg-deep);border:1px solid var(--border);border-radius:var(--radius);padding:16px;display:flex;gap:12px;">
        <div style="flex:1;display:flex;flex-direction:column;gap:8px;">
          <input type="text" class="admin-input" placeholder="Question" value="${escHtml(faq.q)}" id="fq-q-${i}" />
          <textarea class="admin-textarea" placeholder="Answer" id="fq-a-${i}" style="min-height:60px;">${escHtml(faq.a)}</textarea>
        </div>
        <button onclick="removeAdminFAQ(${i})" style="background:none;border:1px solid var(--border);border-radius:8px;color:var(--text-muted);padding:8px;cursor:pointer;height:fit-content;align-self:flex-start;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    `).join('');
  }

  function addAdminFAQ() {
    const s = getSettings();
    s.faqs.push({ q: 'New Question?', a: 'Answer here.' });
    saveSettings(s);
    renderAdminFAQs(s.faqs);
  }

  function removeAdminFAQ(i) {
    const s = getSettings();
    s.faqs.splice(i, 1);
    saveSettings(s);
    renderAdminFAQs(s.faqs);
    renderFAQs(s.faqs);
  }

  function saveAdminSettings() {
    const s = getSettings();
    s.badge = document.getElementById('a-badge').value;
    s.title1 = document.getElementById('a-title1').value;
    s.title2 = document.getElementById('a-title2').value;
    s.subtitle = document.getElementById('a-subtitle').value;
    s.heroDiscord = document.getElementById('a-hero-discord').value;
    s.discordUrl = document.getElementById('a-discord-url').value;
    s.supportUrl = document.getElementById('a-support-url').value;
    s.discordTitle = document.getElementById('a-discord-title').value;
    s.discordDesc = document.getElementById('a-discord-desc').value;
    s.discordBtn = document.getElementById('a-discord-btn').value;
    s.footerDesc = document.getElementById('a-footer-desc').value;
    s.footerCopy = document.getElementById('a-footer-copy').value;

    // Collect features from admin inputs
    const featureCount = document.querySelectorAll('[id^="af-title-"]').length;
    s.features = [];
    for (let i = 0; i < featureCount; i++) {
      const t = document.getElementById(`af-title-${i}`);
      const d = document.getElementById(`af-desc-${i}`);
      if (t && d) s.features.push({ title: t.value, desc: d.value });
    }

    // Collect FAQs
    const faqCount = document.querySelectorAll('[id^="fq-q-"]').length;
    s.faqs = [];
    for (let i = 0; i < faqCount; i++) {
      const q = document.getElementById(`fq-q-${i}`);
      const a = document.getElementById(`fq-a-${i}`);
      if (q && a) s.faqs.push({ q: q.value, a: a.value });
    }

    saveSettings(s);
    applySettings(s);

    const msg = document.getElementById('admin-success-msg');
    msg.classList.add('show');
    setTimeout(() => msg.classList.remove('show'), 3000);
    showToast('Settings saved successfully.');
  }

  /* ============================================================
     ADMIN ROUTE (/admin or #admin)
     ============================================================ */
  function checkAdminRoute() {
    if (window.location.hash === '#admin' || window.location.pathname.endsWith('/admin') || window.location.search.includes('admin=1')) {
      openAdmin();
    }
  }
  window.addEventListener('hashchange', () => {
    if (window.location.hash === '#admin') openAdmin();
  });

  /* ============================================================
     KEYBOARD SHORTCUTS
     ============================================================ */
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      closeCart();
      closeMobileNav();
      if (document.getElementById('product-page').classList.contains('open')) closeProductPage();
      if (document.getElementById('all-products-page').classList.contains('open')) closeAllProductsPage();
    }
  });

  /* ============================================================
     INIT
     ============================================================ */
  async function init() {
    // Apply settings immediately
    const settings = getSettings();
    applySettings(settings);

    // Load Komerza store
    await loadStore();

    // Update cart count
    updateCartCount();

    // Animate hero
    observeAnimations();

    // Check admin route
    checkAdminRoute();

    // Hide page loader
    setTimeout(() => {
      const loader = document.getElementById('page-loader');
      loader.classList.add('hidden');
      setTimeout(() => loader.remove(), 700);
    }, 800);
  }

  // Wait for Komerza script to load
  if (typeof komerza !== 'undefined') {
    init();
  } else {
    window.addEventListener('load', init);
  }
</script>
</body>
</html>

