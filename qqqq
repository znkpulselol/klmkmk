          <div class="cart-item-details">
            <div class="cart-item-name">${escHtml(name)}</div>
            ${variantName ? `<div class="cart-item-variant">${escHtml(variantName)}</div>` : ''}
            <div class="cart-item-price">${escHtml(priceStr)} x ${item.quantity}</div>
          </div>
          <button class="cart-item-remove" onclick="removeCartItem('${item.productId}','${item.variantId}')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      `;
    });

    // Replace list content keeping empty state
    listEl.innerHTML = html;
    const totalEl = document.getElementById('cart-total-price');
    if (totalEl) totalEl.textContent = formatter ? formatter.format(total) : '$' + (total/100).toFixed(2);
    updateCartCount();
  }

