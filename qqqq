  async function doCheckout() {
    const email = document.getElementById('cart-email')?.value?.trim();
    const coupon = document.getElementById('cart-coupon')?.value?.trim();
    const errEl = document.getElementById('cart-error');
    const btn = document.getElementById('cart-checkout-btn');

    if (errEl) errEl.textContent = '';

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (errEl) errEl.textContent = 'Please enter a valid email address.';
      return;
    }

    const basket = komerza.getBasket();
    if (!basket || basket.length === 0) {
      if (errEl) errEl.textContent = 'Your cart is empty.';
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = 'Processing...'; }
    komerza.createBasketBackup && komerza.createBasketBackup();

    try {
      const order = await komerza.checkout(email, coupon || undefined);
      if (order.success && order.data?.gatewayMetadata?.clientSecret) {
        window.location.href = order.data.gatewayMetadata.clientSecret;
      } else if (order.success && order.data?.url) {
        window.location.href = order.data.url;
      } else {
        throw new Error(order.message || 'Checkout failed');
      }
    } catch(e) {
      komerza.restoreBasketFromBackup && komerza.restoreBasketFromBackup();
      if (errEl) errEl.textContent = e.message || 'Checkout failed. Please try again.';
      if (btn) { btn.disabled = false; btn.textContent = 'Complete Purchase'; }
    }
  }

