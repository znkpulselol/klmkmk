  function selectVariant(variantId) {
    if (!currentProduct) return;
    currentVariantId = variantId;
    const variant = currentProduct.variants.find(v => v.id === variantId);
    if (!variant) return;

    // Update price
    const priceEl = document.getElementById('pp-price');
    if (priceEl) priceEl.textContent = formatter ? formatter.format(variant.cost) : '$'+(variant.cost/100).toFixed(2);

    // Update stock
    const stockEl = document.getElementById('pp-stock');
    if (stockEl) {
      let stockHtml = '';
      if (variant.stockMode === 1) {
        stockHtml = `<div class="stock-indicator"><div class="stock-dot in"></div><span style="color:#86efac;">In Stock</span></div>`;
      } else if (variant.stock === 0) {
        stockHtml = `<div class="stock-indicator"><div class="stock-dot out"></div><span style="color:#fca5a5;">Out of Stock</span></div>`;
      } else if (variant.stock < 10) {
        stockHtml = `<div class="stock-indicator"><div class="stock-dot low"></div><span style="color:#fde68a;">Only ${variant.stock} left</span></div>`;
      } else {
        stockHtml = `<div class="stock-indicator"><div class="stock-dot in"></div><span style="color:#86efac;">In Stock</span></div>`;
      }
      stockEl.innerHTML = stockHtml;
    }

    // Highlight selected variant
    document.querySelectorAll('.variant-btn').forEach(btn => btn.classList.remove('selected'));
    // Find the button with this variant
    document.querySelectorAll('.variant-btn').forEach(btn => {
      if (btn.getAttribute('onclick') && btn.getAttribute('onclick').includes(variantId)) {
        btn.classList.add('selected');
      }
    });

    // Update add btn disabled
    const addBtn = document.getElementById('pp-add-btn');
    if (addBtn) {
      const isOut = variant.stockMode !== 1 && variant.stock === 0;
      addBtn.disabled = isOut;
    }

    // Update gallery if variant has images
    if (variant.imageNames && variant.imageNames.length > 0) {
      const mainImg = document.getElementById('gallery-main-img');
      if (mainImg) mainImg.src = getImgUrl(currentProduct.id, variant.imageNames[0]);
    }
