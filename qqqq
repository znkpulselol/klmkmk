  function changeQty(delta) {
    const input = document.getElementById('pp-qty');
    if (!input) return;
    let val = parseInt(input.value) + delta;
    const min = parseInt(input.min) || 1;
    const max = parseInt(input.max) || 99;
    val = Math.max(min, Math.min(max, val));
    input.value = val;
  }

