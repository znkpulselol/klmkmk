<script>
  /* ============================================================
     KOMERZA INIT
     ============================================================ */
  const STORE_ID = 'a682b6fd-fb35-4866-b74f-715301caa309';


  let storeData = null;
  let formatter = null;
  let allProducts = [];
  let activeProductFilter = 'all';
  let currentProduct = null;
  let currentVariantId = null;
  // Track click counts for "Best Products"
  let clickCounts = JSON.parse(localStorage.getItem('refract_clicks') || '{}');

  function getImgUrl(productId, imageName) {
    if (!imageName) return "";
    return `https://user-generated-content.komerza.com/${imageName}`;
  }

  /* ============================================================
     ADMIN SETTINGS (localStorage)
     ============================================================ */
  const SETTINGS_KEY = 'refract_settings';
  const defaultSettings = {
    badge: 'Premium Gaming Store',
    title1: 'Elevate Your',
    title2: 'Gaming Experience',
    subtitle: 'Exclusive digital products curated for the most demanding players. Top-tier quality, instant delivery, unmatched support.',
    heroDiscord: 'Join Discord',
    discordUrl: 'https://discord.gg/USPYEFetgP',
    supportUrl: 'https://discord.gg/USPYEFetgP',
    discordTitle: 'Join Our Community',
    discordDesc: 'Connect with thousands of gamers. Get exclusive deals, support and more.',
    discordBtn: 'Join Discord',
    footerDesc: 'The premium gaming destination. Exclusive digital products, top-tier quality, instant delivery.',
    footerCopy: '© 2025 REFRACT. All rights reserved.',
    sections: {
      hero: true, products: true, 'best-section': true,
      categories: true, why: true, 'discord-section': true, faq: true
    },
    features: [
      { title: 'Instant Delivery', desc: 'All products are delivered digitally within seconds of purchase. No waiting, no shipping.' },
      { title: 'Premium Quality', desc: 'Every product is hand-selected for maximum quality and performance.' },
      { title: '24/7 Support', desc: 'Our dedicated support team is available around the clock via Discord.' },
      { title: 'Secure Checkout', desc: 'All transactions are encrypted and processed securely through our trusted payment gateway.' },
      { title: 'Exclusive Products', desc: 'Access to premium gaming tools and digital goods not available anywhere else.' },
      { title: 'Community', desc: 'Join thousands of gamers in our Discord community for tips, deals, and more.' }
    ],
    faqs: [
      { q: 'How fast is delivery?', a: 'All digital products are delivered instantly after payment confirmation. You will receive access immediately.' },
      { q: 'What payment methods are accepted?', a: 'We accept all major credit cards, PayPal, and various other payment methods through our secure checkout.' },
      { q: 'Can I get a refund?', a: 'Due to the digital nature of our products, refunds are handled case-by-case. Please contact our support team on Discord.' },
      { q: 'Is my purchase secure?', a: 'Yes, all transactions are encrypted using industry-standard SSL encryption. Your data is always safe.' },
      { q: 'Where can I get support?', a: 'Join our Discord server for instant support from our team and community members.' }
    ]
  };

  function getSettings() {
    try {
      const stored = localStorage.getItem(SETTINGS_KEY);
      if (stored) return Object.assign({}, defaultSettings, JSON.parse(stored));
    } catch(e) {}
    return JSON.parse(JSON.stringify(defaultSettings));
  }

  function saveSettings(settings) {
    localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings));
  }

  function applySettings(settings) {
    // Hero
    document.getElementById('hero-badge-text').textContent = settings.badge;
    document.getElementById('hero-title-line1').textContent = settings.title1;
    document.getElementById('hero-title-line2').textContent = settings.title2;
    document.getElementById('hero-subtitle').textContent = settings.subtitle;

    // Discord links
    const discordUrl = settings.discordUrl || 'https://discord.gg/USPYEFetgP';
    document.querySelectorAll('a[id="hero-discord-btn"], a.btn-discord, .footer-links a[href*="discord"]').forEach(el => {
      if (el.href !== undefined) el.href = discordUrl;
    });
    const heroDiscBtn = document.getElementById('hero-discord-btn');
    if (heroDiscBtn) heroDiscBtn.textContent = settings.heroDiscord || 'Join Discord';

    // Discord banner
    document.getElementById('discord-title').textContent = settings.discordTitle;
    document.getElementById('discord-desc').textContent = settings.discordDesc;
    const discordCtaBtn = document.getElementById('discord-cta-btn');
    if (discordCtaBtn) { discordCtaBtn.href = discordUrl; }

    // Footer
    document.getElementById('footer-desc').textContent = settings.footerDesc;
    document.getElementById('footer-copy').textContent = settings.footerCopy;

    // Sections
    const sections = settings.sections || defaultSettings.sections;
    Object.entries(sections).forEach(([id, visible]) => {
      const el = document.getElementById(id);
      if (el) el.style.display = visible ? '' : 'none';
      const toggle = document.getElementById('t-' + id);
      if (toggle) {
        toggle.classList.toggle('on', visible);
      }
    });

    // Features
    renderFeatures(settings.features);
    // FAQs
    renderFAQs(settings.faqs);
  }

  /* ============================================================
     RENDER FEATURES
     ============================================================ */
  const featureIcons = [
    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  ];

  function renderFeatures(features) {
    const grid = document.getElementById('features-grid');
    if (!grid) return;
    grid.innerHTML = features.map((f, i) => `
      <div class="feature-card fade-in-up">
        <div class="feature-icon">${featureIcons[i % featureIcons.length]}</div>
        <h3 class="feature-title">${escHtml(f.title)}</h3>
        <p class="feature-desc">${escHtml(f.desc)}</p>
      </div>
    `).join('');
    observeAnimations();
  }

  /* ============================================================
     RENDER FAQs
     ============================================================ */
  function renderFAQs(faqs) {
    const list = document.getElementById('faq-list');
    if (!list) return;
    list.innerHTML = faqs.map((faq, i) => `
      <div class="faq-item" id="faq-${i}">
        <div class="faq-question" onclick="toggleFAQ(${i})">
          <span>${escHtml(faq.q)}</span>
          <div class="faq-icon">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </div>
        </div>
        <div class="faq-answer">${escHtml(faq.a)}</div>
      </div>
    `).join('');
  }

  function toggleFAQ(i) {
    const item = document.getElementById('faq-' + i);
    item.classList.toggle('open');
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ============================================================
     PRODUCT CARD HTML
     ============================================================ */
  function getProductPrice(product) {
    if (!product.variants || product.variants.length === 0) return null;
    const prices = product.variants.map(v => v.cost).filter(c => c != null);
    if (prices.length === 0) return null;
    return Math.min(...prices);
  }

  function buildProductCard(product, showBadge) {
    const price = getProductPrice(product);
    const priceStr = price != null ? (formatter ? formatter.format(price) : '$' + (price/100).toFixed(2)) : 'See options';
    const imgName = product.imageNames && product.imageNames.length > 0 ? product.imageNames[0] : null;
    const imgUrl = imgName ? getImgUrl(product.id, imgName) : null;
    const badge = showBadge || '';

    return `
      <div class="product-card fade-in-up" onclick="openProductPage('${product.id}')">
        <div class="product-img-wrap">
          ${imgUrl
            ? `<img src="${imgUrl}" alt="${escHtml(product.name)}" loading="lazy" onerror="handleImgError(this)" />`
            : `<div class="product-img-placeholder">${placeholderSVG()}</div>`
          }
          ${badge ? `<div class="product-badge">${escHtml(badge)}</div>` : ''}
        </div>
        <div class="product-info">
          <h3 class="product-name">${escHtml(product.name)}</h3>
          <p class="product-desc">${escHtml(product.description || 'Premium gaming product.')}</p>
          <div class="product-footer">
            <div class="product-price">
              <span class="product-price-from">${product.variants && product.variants.length > 1 ? 'From ' : ''}</span>${escHtml(priceStr)}
            </div>
            <div class="product-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </div>
          </div>
        </div>
      </div>
    `;
  }

  function placeholderSVG() {
    return `<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="2" y="2" width="20" height="20" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
  }

  function handleImgError(imgEl) {
    imgEl.parentElement.innerHTML = `<div class="product-img-placeholder">${placeholderSVG()}</div>`;
  }

  /* ============================================================
     LOAD STORE DATA
     ============================================================ */
  async function loadStore() {
    try {
      komerza.init(STORE_ID);
      const [storeResp, fmt] = await Promise.all([
        komerza.getStore(),
        komerza.createFormatter()
      ]);
      formatter = fmt;

      if (!storeResp.success) throw new Error('Store not loaded');
      storeData = storeResp.data;
      allProducts = storeData.products || [];

      // Update hero stat
      document.getElementById('stat-products').textContent = allProducts.length + '+';

      // Render featured products (first 4)
      renderFeaturedProducts();
      // Render best products (by click count)
      renderBestProducts();
      // Render categories
      renderCategories();
      // Render all products grid
      renderAllProducts();
      // Update filter buttons
      updateCategoryFilterBtns();

    } catch(e) {
      console.error('Komerza load error:', e);
      document.getElementById('featured-products-grid').innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);">Unable to load products. Please refresh.</div>`;
      document.getElementById('all-products-grid').innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);">Unable to load products. Please refresh.</div>`;
    }
  }

  function renderFeaturedProducts() {
    const grid = document.getElementById('featured-products-grid');
    const featured = allProducts.slice(0, 4);
    if (featured.length === 0) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);">No products found.</div>`;
      return;
    }
    grid.innerHTML = featured.map(p => buildProductCard(p, 'Featured')).join('');
    observeAnimations();
  }

  function renderBestProducts() {
    const grid = document.getElementById('best-products-grid');
    // Sort by click count descending, take top 3
    const sorted = [...allProducts].sort((a, b) => (clickCounts[b.id] || 0) - (clickCounts[a.id] || 0));
    const best = sorted.slice(0, 3);
    if (best.length === 0) {
      grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted);">No products found.</div>`;
      return;
    }
    grid.innerHTML = best.map(p => buildProductCard(p, 'Popular')).join('');
    observeAnimations();
  }

  function renderCategories() {
    const grid = document.getElementById('categories-grid');
    // Extract unique categories from product tags/collections
    const catMap = {};
    allProducts.forEach(p => {
      // Komerza products may have tags or categories
      const cats = p.tags || p.categories || p.collections || [];
      if (Array.isArray(cats)) {
        cats.forEach(c => {
          const name = typeof c === 'string' ? c : (c.name || c);
